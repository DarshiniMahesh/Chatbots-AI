    "# Cell 2 — Imports\n",
    "import anthropic\n",
    "import PyPDF2\n",
    "import io\n",
    "import ipywidgets as widgets\n",
    "from IPython.display import display, clear_output, HTML\n",
    "from google.colab import files\n",
    "\n",
    "print('✅ Imports ready!')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Cell 3 — Setup Anthropic client\n",
    "# Get your FREE API key from: https://console.anthropic.com\n",
    "# New accounts get free credits — no payment needed to start\n",
    "\n",
    "API_KEY = \"your-api-key-here\"   # <-- paste your key here\n",
    "\n",
    "client = anthropic.Anthropic(api_key=API_KEY)\n",
    "print('✅ Client ready!')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Cell 4 — Core rewrite function\n",
    "\n",
    "def rewrite_resume(resume_text, job_role, job_description):\n",
    "    \"\"\"\n",
    "    Sends resume + JD to Claude API.\n",
    "    Returns a fully optimized resume as plain text.\n",
    "    \"\"\"\n",
    "\n",
    "    # Build the JD part of the prompt\n",
    "    jd_section = \"\"\n",
    "    if job_description.strip():\n",
    "        jd_section = f\"\"\"\n",
    "JOB DESCRIPTION:\n",
    "{job_description}\n",
    "\"\"\"\n",
    "    else:\n",
    "        jd_section = f\"The target role is: {job_role}. Optimize the resume for this role.\"\n",
    "\n",
    "    prompt = f\"\"\"You are an expert resume writer.\n",
    "\n",
    "Your task is to rewrite the resume below and make it highly optimized for the given job role and job description.\n",
    "\n",
    "STRICT RULES:\n",
    "1. Keep the EXACT same sections and structure as the original resume.\n",
    "2. Keep all real facts — name, college, CGPA, project names, company names. Do NOT invent anything.\n",
    "3. Rewrite each section to be professional, impactful, and ATS-friendly.\n",
    "4. Use strong action verbs (developed, built, implemented, tested, optimized, etc.).\n",
    "5. Naturally add relevant keywords from the job description into skills, projects, and experience.\n",
    "6. Do NOT add fake experience, fake skills, or fake certifications.\n",
    "7. Do NOT add any explanation, commentary, or notes — output ONLY the rewritten resume.\n",
    "8. Preserve the formatting style of the original (use same labels like NAME:, SKILLS:, etc.)\n",
    "\n",
    "TARGET JOB ROLE: {job_role}\n",
    "\n",
    "{jd_section}\n",
    "\n",
    "ORIGINAL RESUME:\n",
    "{resume_text}\n",
    "\n",
    "OUTPUT: Rewritten resume only. No extra text.\"\"\"\n",
    "\n",
    "    message = client.messages.create(\n",
    "        model=\"claude-haiku-4-5-20251001\",   # fast + free-tier friendly\n",
    "        max_tokens=2000,\n",
    "        messages=[\n",
    "            {\"role\": \"user\", \"content\": prompt}\n",
    "        ]\n",
    "    )\n",
    "\n",
    "    return message.content[0].text.strip()\n",
    "\n",
    "\n",
    "print('✅ Function ready!')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
